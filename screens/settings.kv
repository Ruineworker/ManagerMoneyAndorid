<SettingsScreen>:
    md_bg_color: app.ui("bg")

    MDBoxLayout:
        orientation: "vertical"

        MDBoxLayout:
            orientation: "vertical"
            size_hint_y: None
            height: "96dp"
            padding: "20dp", "18dp", "20dp", "10dp"

            MDLabel:
                text: "Настройки"
                font_style: "Title"
                theme_text_color: "Custom"
                text_color: app.ui("text")
                bold: True
            MDLabel:
                text: "Тема, валюта и управление данными"
                theme_text_color: "Custom"
                text_color: app.ui("text_soft")

        ScrollView:
            do_scroll_x: False
            bar_width: 0

            MDBoxLayout:
                orientation: "vertical"
                adaptive_height: True
                spacing: "16dp"
                padding: "16dp", "0dp", "16dp", "16dp"

                MDCard:
                    style: "filled"
                    md_bg_color: app.ui("surface")
                    radius: [24, 24, 24, 24]
                    padding: "16dp"
                    size_hint_y: None
                    height: content1.minimum_height + dp(32)

                    MDBoxLayout:
                        id: content1
                        orientation: "vertical"
                        adaptive_height: True
                        spacing: "12dp"

                        MDLabel:
                            text: "Валюта"
                            theme_text_color: "Custom"
                            text_color: app.ui("text")
                            bold: True
                        Spinner:
                            id: currency_spinner
                            text: "Выберите валюту"
                            values: ["₽", "$", "€"]
                            size_hint_y: None
                            height: "48dp"
                            background_color: app.ui("input")
                            color: app.ui("text")
                            on_text: root.set_currency(self.text)

                        MDLabel:
                            text: "Тема"
                            theme_text_color: "Custom"
                            text_color: app.ui("text")
                            bold: True
                        Spinner:
                            id: theme_spinner
                            text: "Светлая"
                            values: ["Светлая", "Тёмная"]
                            size_hint_y: None
                            height: "48dp"
                            background_color: app.ui("input")
                            color: app.ui("text")
                            on_text: root.set_theme(self.text)

                MDCard:
                    style: "filled"
                    md_bg_color: app.ui("surface")
                    radius: [24, 24, 24, 24]
                    padding: "16dp"
                    size_hint_y: None
                    height: content2.minimum_height + dp(32)

                    MDBoxLayout:
                        id: content2
                        orientation: "vertical"
                        adaptive_height: True
                        spacing: "12dp"

                        Button:
                            text: "Категории"
                            background_normal: ""
                            background_down: ""
                            background_color: app.ui("card_alt")
                            color: app.ui("text")
                            size_hint_y: None
                            height: "48dp"
                            on_release: app.root.current = "categories"

                        Button:
                            text: "Сделать резервную копию"
                            background_normal: ""
                            background_down: ""
                            background_color: app.ui("primary")
                            color: 0.08, 0.14, 0.16, 1
                            bold: True
                            size_hint_y: None
                            height: "48dp"
                            on_release: root.backup_database()

                        Button:
                            text: "Сбросить демо-данные"
                            background_normal: ""
                            background_down: ""
                            background_color: app.ui("card_alt")
                            color: app.ui("expense")
                            size_hint_y: None
                            height: "48dp"
                            on_release: root.reset_demo()

                        MDLabel:
                            id: info_label
                            text: ""
                            theme_text_color: "Custom"
                            text_color: app.ui("text_soft")
                            size_hint_y: None
                            height: self.texture_size[1] if self.text else 0

        MDCard:
            style: "filled"
            size_hint_y: None
            height: "82dp"
            radius: [26, 26, 0, 0]
            md_bg_color: app.ui("nav")
            padding: "6dp", "10dp", "6dp", "10dp"

            MDGridLayout:
                cols: 5
                spacing: "6dp"

                Button:
                    text: "Главная"
                    background_normal: ""
                    background_down: ""
                    background_color: app.ui("nav_active") if root.name == "dashboard" else (0, 0, 0, 0)
                    color: (0.12, 0.22, 0.24, 1) if root.name == "dashboard" else app.ui("text_soft")
                    bold: root.name == "dashboard"
                    on_release: app.root.current = "dashboard"
                Button:
                    text: "Операции"
                    background_normal: ""
                    background_down: ""
                    background_color: app.ui("nav_active") if root.name == "transactions" else (0, 0, 0, 0)
                    color: (0.12, 0.22, 0.24, 1) if root.name == "transactions" else app.ui("text_soft")
                    bold: root.name == "transactions"
                    on_release: app.root.current = "transactions"
                Button:
                    text: "Аналитика"
                    background_normal: ""
                    background_down: ""
                    background_color: app.ui("nav_active") if root.name == "analytics" else (0, 0, 0, 0)
                    color: (0.12, 0.22, 0.24, 1) if root.name == "analytics" else app.ui("text_soft")
                    bold: root.name == "analytics"
                    on_release: app.root.current = "analytics"
                Button:
                    text: "Счета"
                    background_normal: ""
                    background_down: ""
                    background_color: app.ui("nav_active") if root.name == "accounts" else (0, 0, 0, 0)
                    color: (0.12, 0.22, 0.24, 1) if root.name == "accounts" else app.ui("text_soft")
                    bold: root.name == "accounts"
                    on_release: app.root.current = "accounts"
                Button:
                    text: "Настройки"
                    background_normal: ""
                    background_down: ""
                    background_color: app.ui("nav_active") if root.name == "settings" else (0, 0, 0, 0)
                    color: (0.12, 0.22, 0.24, 1) if root.name == "settings" else app.ui("text_soft")
                    bold: root.name == "settings"
                    on_release: app.root.current = "settings"

