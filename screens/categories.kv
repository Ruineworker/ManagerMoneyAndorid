<CategoryRow@MDCard>:
    icon_text: "tag"
    title_text: ""
    subtitle_text: ""
    style: "filled"
    md_bg_color: app.ui("card")
    radius: [18, 18, 18, 18]
    padding: "14dp"
    size_hint_y: None
    height: "64dp"

    MDBoxLayout:
        spacing: "10dp"

        MDIcon:
            icon: root.icon_text
            size_hint_x: None
            width: "28dp"
            theme_text_color: "Custom"
            text_color: app.ui("primary")
        MDLabel:
            text: root.title_text
            theme_text_color: "Custom"
            text_color: app.ui("text")
            bold: True
        MDLabel:
            text: root.subtitle_text
            halign: "right"
            theme_text_color: "Custom"
            text_color: app.ui("text_soft")

<CategoriesScreen>:
    md_bg_color: app.ui("bg")

    MDBoxLayout:
        orientation: "vertical"

        MDBoxLayout:
            orientation: "vertical"
            size_hint_y: None
            height: "96dp"
            padding: "20dp", "18dp", "20dp", "10dp"

            MDLabel:
                text: "Категории"
                font_style: "Title"
                theme_text_color: "Custom"
                text_color: app.ui("text")
                bold: True
            MDLabel:
                text: "Категории доходов и расходов"
                theme_text_color: "Custom"
                text_color: app.ui("text_soft")

        MDBoxLayout:
            size_hint_y: None
            height: "48dp"
            padding: "16dp", "0dp", "16dp", "0dp"
            spacing: "10dp"

            Button:
                id: expense_btn
                text: "Расход"
                background_normal: ""
                background_down: ""
                on_release: root.set_type("expense")
            Button:
                id: income_btn
                text: "Доход"
                background_normal: ""
                background_down: ""
                on_release: root.set_type("income")

        MDRecycleView:
            id: categories_rv
            viewclass: "CategoryRow"

            RecycleBoxLayout:
                default_size: None, dp(64)
                default_size_hint: 1, None
                size_hint_y: None
                height: self.minimum_height
                orientation: "vertical"
                spacing: dp(10)
                padding: dp(16), dp(12), dp(16), dp(16)

        MDCard:
            style: "filled"
            size_hint_y: None
            height: "82dp"
            radius: [26, 26, 0, 0]
            md_bg_color: app.ui("nav")
            padding: "6dp", "10dp", "6dp", "10dp"

            MDGridLayout:
                cols: 5
                spacing: "6dp"

                Button:
                    text: "Главная"
                    background_normal: ""
                    background_down: ""
                    background_color: app.ui("nav_active") if root.name == "dashboard" else (0, 0, 0, 0)
                    color: (0.12, 0.22, 0.24, 1) if root.name == "dashboard" else app.ui("text_soft")
                    bold: root.name == "dashboard"
                    on_release: app.root.current = "dashboard"
                Button:
                    text: "Операции"
                    background_normal: ""
                    background_down: ""
                    background_color: app.ui("nav_active") if root.name == "transactions" else (0, 0, 0, 0)
                    color: (0.12, 0.22, 0.24, 1) if root.name == "transactions" else app.ui("text_soft")
                    bold: root.name == "transactions"
                    on_release: app.root.current = "transactions"
                Button:
                    text: "Аналитика"
                    background_normal: ""
                    background_down: ""
                    background_color: app.ui("nav_active") if root.name == "analytics" else (0, 0, 0, 0)
                    color: (0.12, 0.22, 0.24, 1) if root.name == "analytics" else app.ui("text_soft")
                    bold: root.name == "analytics"
                    on_release: app.root.current = "analytics"
                Button:
                    text: "Счета"
                    background_normal: ""
                    background_down: ""
                    background_color: app.ui("nav_active") if root.name == "accounts" else (0, 0, 0, 0)
                    color: (0.12, 0.22, 0.24, 1) if root.name == "accounts" else app.ui("text_soft")
                    bold: root.name == "accounts"
                    on_release: app.root.current = "accounts"
                Button:
                    text: "Настройки"
                    background_normal: ""
                    background_down: ""
                    background_color: app.ui("nav_active") if root.name == "settings" else (0, 0, 0, 0)
                    color: (0.12, 0.22, 0.24, 1) if root.name == "settings" else app.ui("text_soft")
                    bold: root.name == "settings"
                    on_release: app.root.current = "settings"

