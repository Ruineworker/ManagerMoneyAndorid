<DashboardScreen>:
    md_bg_color: app.ui("bg")

    MDBoxLayout:
        orientation: "vertical"

        MDBoxLayout:
            orientation: "vertical"
            size_hint_y: None
            height: "96dp"
            padding: "20dp", "18dp", "20dp", "10dp"

            MDLabel:
                text: "Главная"
                font_style: "Title"
                theme_text_color: "Custom"
                text_color: app.ui("text")
                bold: True

            MDLabel:
                text: "Ваши деньги под контролем"
                theme_text_color: "Custom"
                text_color: app.ui("text_soft")

        ScrollView:
            do_scroll_x: False
            bar_width: 0

            MDBoxLayout:
                orientation: "vertical"
                adaptive_height: True
                spacing: "16dp"
                padding: "16dp", "0dp", "16dp", "16dp"

                MDCard:
                    style: "filled"
                    md_bg_color: app.ui("hero")
                    radius: [24, 24, 24, 24]
                    size_hint_y: None
                    height: "176dp"
                    padding: "20dp"

                    MDBoxLayout:
                        orientation: "vertical"
                        spacing: "8dp"

                        MDLabel:
                            text: "Общий баланс"
                            theme_text_color: "Custom"
                            text_color: app.ui("text_on_dark")
                            opacity: .85

                        MDLabel:
                            id: balance_label
                            text: "₽0.00"
                            theme_text_color: "Custom"
                            text_color: app.ui("text_on_dark")
                            font_size: "34sp"
                            bold: True

                        Widget:
                        MDLabel:
                            id: updated_label
                            text: "Операций в этом месяце: 0"
                            theme_text_color: "Custom"
                            text_color: app.ui("text_on_dark")
                            opacity: .72

                GridLayout:
                    cols: 2
                    spacing: "12dp"
                    size_hint_y: None
                    height: self.minimum_height

                    MDCard:
                        style: "filled"
                        md_bg_color: app.ui("card_alt")
                        radius: [20, 20, 20, 20]
                        size_hint_y: None
                        height: "108dp"
                        padding: "18dp"

                        MDBoxLayout:
                            orientation: "vertical"

                            MDLabel:
                                text: "Доход"
                                theme_text_color: "Custom"
                                text_color: app.ui("text")
                            Widget:
                            MDLabel:
                                id: income_label
                                text: "₽0.00"
                                theme_text_color: "Custom"
                                text_color: app.ui("success")
                                bold: True
                                font_size: "24sp"

                    MDCard:
                        style: "filled"
                        md_bg_color: app.ui("card_alt")
                        radius: [20, 20, 20, 20]
                        size_hint_y: None
                        height: "108dp"
                        padding: "18dp"

                        MDBoxLayout:
                            orientation: "vertical"

                            MDLabel:
                                text: "Расход"
                                theme_text_color: "Custom"
                                text_color: app.ui("text")
                            Widget:
                            MDLabel:
                                id: expense_label
                                text: "₽0.00"
                                theme_text_color: "Custom"
                                text_color: app.ui("expense")
                                bold: True
                                font_size: "24sp"

                MDLabel:
                    text: "Быстрые действия"
                    font_style: "Title"
                    theme_text_color: "Custom"
                    text_color: app.ui("text")
                    bold: True
                    size_hint_y: None
                    height: self.texture_size[1]

                GridLayout:
                    cols: 2
                    spacing: "12dp"
                    size_hint_y: None
                    height: "54dp"

                    Button:
                        text: "+ Доход"
                        background_normal: ""
                        background_down: ""
                        background_color: app.ui("primary")
                        color: 0.07, 0.14, 0.16, 1
                        bold: True
                        on_release: root.open_add("income")

                    Button:
                        text: "+ Расход"
                        background_normal: ""
                        background_down: ""
                        background_color: app.ui("primary_soft")
                        color: 0.12, 0.22, 0.24, 1
                        bold: True
                        on_release: root.open_add("expense")

                MDBoxLayout:
                    size_hint_y: None
                    height: "28dp"

                    MDLabel:
                        text: "Последние операции"
                        font_style: "Title"
                        theme_text_color: "Custom"
                        text_color: app.ui("text")
                        bold: True

                    Button:
                        text: "Смотреть все"
                        size_hint_x: None
                        width: "122dp"
                        background_normal: ""
                        background_down: ""
                        background_color: 0, 0, 0, 0
                        color: app.ui("primary")
                        on_release: app.root.current = "transactions"

                MDBoxLayout:
                    id: recent_box
                    orientation: "vertical"
                    adaptive_height: True
                    spacing: "10dp"

                Widget:
                    size_hint_y: None
                    height: "8dp"

        MDCard:
            style: "filled"
            size_hint_y: None
            height: "82dp"
            radius: [26, 26, 0, 0]
            md_bg_color: app.ui("nav")
            padding: "6dp", "10dp", "6dp", "10dp"

            MDGridLayout:
                cols: 5
                spacing: "6dp"

                Button:
                    text: "Главная"
                    background_normal: ""
                    background_down: ""
                    background_color: app.ui("nav_active") if root.name == "dashboard" else (0, 0, 0, 0)
                    color: (0.12, 0.22, 0.24, 1) if root.name == "dashboard" else app.ui("text_soft")
                    bold: root.name == "dashboard"
                    on_release: app.root.current = "dashboard"
                Button:
                    text: "Операции"
                    background_normal: ""
                    background_down: ""
                    background_color: app.ui("nav_active") if root.name == "transactions" else (0, 0, 0, 0)
                    color: (0.12, 0.22, 0.24, 1) if root.name == "transactions" else app.ui("text_soft")
                    bold: root.name == "transactions"
                    on_release: app.root.current = "transactions"
                Button:
                    text: "Аналитика"
                    background_normal: ""
                    background_down: ""
                    background_color: app.ui("nav_active") if root.name == "analytics" else (0, 0, 0, 0)
                    color: (0.12, 0.22, 0.24, 1) if root.name == "analytics" else app.ui("text_soft")
                    bold: root.name == "analytics"
                    on_release: app.root.current = "analytics"
                Button:
                    text: "Счета"
                    background_normal: ""
                    background_down: ""
                    background_color: app.ui("nav_active") if root.name == "accounts" else (0, 0, 0, 0)
                    color: (0.12, 0.22, 0.24, 1) if root.name == "accounts" else app.ui("text_soft")
                    bold: root.name == "accounts"
                    on_release: app.root.current = "accounts"
                Button:
                    text: "Настройки"
                    background_normal: ""
                    background_down: ""
                    background_color: app.ui("nav_active") if root.name == "settings" else (0, 0, 0, 0)
                    color: (0.12, 0.22, 0.24, 1) if root.name == "settings" else app.ui("text_soft")
                    bold: root.name == "settings"
                    on_release: app.root.current = "settings"

