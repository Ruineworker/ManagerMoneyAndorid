<AccountsScreen>:
    md_bg_color: app.ui("bg")

    MDBoxLayout:
        orientation: "vertical"

        MDBoxLayout:
            orientation: "vertical"
            size_hint_y: None
            height: "96dp"
            padding: "20dp", "18dp", "20dp", "10dp"

            MDLabel:
                text: "Счета"
                font_style: "Title"
                theme_text_color: "Custom"
                text_color: app.ui("text")
                bold: True
            MDLabel:
                text: "Управление кошельками и картами"
                theme_text_color: "Custom"
                text_color: app.ui("text_soft")

        ScrollView:
            do_scroll_x: False
            bar_width: 0

            MDBoxLayout:
                orientation: "vertical"
                adaptive_height: True
                spacing: "16dp"
                padding: "16dp", "0dp", "16dp", "16dp"

                MDCard:
                    style: "filled"
                    md_bg_color: app.ui("hero")
                    radius: [24, 24, 24, 24]
                    padding: "18dp"
                    size_hint_y: None
                    height: "116dp"

                    MDBoxLayout:
                        orientation: "vertical"

                        MDLabel:
                            text: "Итого по всем счетам"
                            theme_text_color: "Custom"
                            text_color: app.ui("text_on_dark")
                            opacity: .82
                        Widget:
                        MDLabel:
                            id: total_balance_label
                            text: "₽0.00"
                            theme_text_color: "Custom"
                            text_color: app.ui("text_on_dark")
                            font_size: "30sp"
                            bold: True

                AnchorLayout:
                    anchor_x: "center"
                    size_hint_y: None
                    height: form_card.height

                    MDCard:
                        id: form_card
                        style: "filled"
                        md_bg_color: app.ui("surface")
                        radius: [24, 24, 24, 24]
                        padding: "16dp"
                        size_hint: None, None
                        width: min(root.width - dp(32), dp(360))
                        height: content_box.minimum_height + dp(32)

                        MDBoxLayout:
                            id: content_box
                            orientation: "vertical"
                            adaptive_height: True
                            spacing: "10dp"

                            MDLabel:
                                id: form_title
                                text: "Добавить счёт"
                                theme_text_color: "Custom"
                                text_color: app.ui("text")
                                bold: True
                            MDTextField:
                                id: account_name
                                hint_text: "Название счёта"
                                mode: "outlined"
                                size_hint_y: None
                                height: "52dp"
                            MDTextField:
                                id: account_balance
                                hint_text: "Баланс"
                                mode: "outlined"
                                input_filter: "float"
                                size_hint_y: None
                                height: "52dp"
                            MDLabel:
                                id: account_error
                                text: ""
                                theme_text_color: "Custom"
                                text_color: app.ui("expense")
                                size_hint_y: None
                                height: self.texture_size[1] if self.text else 0
                            GridLayout:
                                cols: 2
                                spacing: "10dp"
                                size_hint_y: None
                                height: "48dp"
                                Button:
                                    id: cancel_btn
                                    text: "Отмена"
                                    background_normal: ""
                                    background_down: ""
                                    background_color: app.ui("card_alt")
                                    color: app.ui("text")
                                    on_release: root.cancel_edit()
                                Button:
                                    id: save_btn
                                    text: "Добавить счёт"
                                    background_normal: ""
                                    background_down: ""
                                    background_color: app.ui("primary")
                                    color: 0.08, 0.14, 0.16, 1
                                    bold: True
                                    on_release: root.save_account()

                MDLabel:
                    text: "Список счетов"
                    theme_text_color: "Custom"
                    text_color: app.ui("text")
                    font_style: "Title"
                    bold: True
                    size_hint_y: None
                    height: self.texture_size[1]

                MDBoxLayout:
                    id: accounts_box
                    orientation: "vertical"
                    adaptive_height: True
                    spacing: "10dp"

        MDCard:
            style: "filled"
            size_hint_y: None
            height: "82dp"
            radius: [26, 26, 0, 0]
            md_bg_color: app.ui("nav")
            padding: "6dp", "10dp", "6dp", "10dp"

            MDGridLayout:
                cols: 5
                spacing: "6dp"

                Button:
                    text: "Главная"
                    background_normal: ""
                    background_down: ""
                    background_color: app.ui("nav_active") if root.name == "dashboard" else (0, 0, 0, 0)
                    color: (0.12, 0.22, 0.24, 1) if root.name == "dashboard" else app.ui("text_soft")
                    bold: root.name == "dashboard"
                    on_release: app.root.current = "dashboard"
                Button:
                    text: "Операции"
                    background_normal: ""
                    background_down: ""
                    background_color: app.ui("nav_active") if root.name == "transactions" else (0, 0, 0, 0)
                    color: (0.12, 0.22, 0.24, 1) if root.name == "transactions" else app.ui("text_soft")
                    bold: root.name == "transactions"
                    on_release: app.root.current = "transactions"
                Button:
                    text: "Аналитика"
                    background_normal: ""
                    background_down: ""
                    background_color: app.ui("nav_active") if root.name == "analytics" else (0, 0, 0, 0)
                    color: (0.12, 0.22, 0.24, 1) if root.name == "analytics" else app.ui("text_soft")
                    bold: root.name == "analytics"
                    on_release: app.root.current = "analytics"
                Button:
                    text: "Счета"
                    background_normal: ""
                    background_down: ""
                    background_color: app.ui("nav_active") if root.name == "accounts" else (0, 0, 0, 0)
                    color: (0.12, 0.22, 0.24, 1) if root.name == "accounts" else app.ui("text_soft")
                    bold: root.name == "accounts"
                    on_release: app.root.current = "accounts"
                Button:
                    text: "Настройки"
                    background_normal: ""
                    background_down: ""
                    background_color: app.ui("nav_active") if root.name == "settings" else (0, 0, 0, 0)
                    color: (0.12, 0.22, 0.24, 1) if root.name == "settings" else app.ui("text_soft")
                    bold: root.name == "settings"
                    on_release: app.root.current = "settings"

